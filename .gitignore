# gitignore file for IP Camera Viewer

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Recordings and snapshots
recordings/
*.mp4
*.jpg
*.jpeg
*.png

# Environment variables
.env
.env.local
.env.*.local

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log

# OS files
Thumbs.db
desktop.ini

# Temporary files
tmp/
temp/
*.tmp

# Build files
dist/
build/

# Camera configuration (sensitive data)
camera-config.json
